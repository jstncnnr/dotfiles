{
    "layer": "top", // Waybar at top layer
    "height": 42, // Waybar height (to be removed for auto height)
    "spacing": 0, // Gaps between modules (4px)
    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": [],
    "modules-right": ["tray", "upower#trackpad", "pulseaudio", "clock", "custom/swaync", "custom/power"],
    // Modules configuration
    "hyprland/workspaces": {
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
	"on-scroll-up": "hyprctl dispatch workspace e+1",
	"on-scroll-down": "hyprctl dispatch workspace e-1",
	"on-click": "activate",
        "format-icons": {
            "1": "´ÇĽ",
            "2": "´é▒",
            "3": "´äŤ",
            "4": "´ć╝",
            "5": "ţ×Ľ",
	    "6": "´ÇŻ",
        },
	"persistent-workspaces": {
	    "*": 6
	}
    },
    "hyprland/window": {
	"max-length": 200
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%m-%d-%Y}",
	"format": "{:%I:%M %p}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
	"reverse-scrolling": 1,
        "format": "{icon} {volume}%  {format_source}",
        "format-bluetooth": "{icon} {volume}%  {format_source}",
        "format-bluetooth-muted": "´Üę {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol",
	"min-length": 13,
	"ignored-sinks": ["Office", "Justin's MacBook Pro"],
    },
    "custom/swaync": {
	"tooltip":true,     
	"format": "{icon}",
	"format-icons": {
	  "notification": "<span color=\"#ebcb8b\">´éó</span>",
	  "none": "´éó",
	  "dnd-notification": "<span color=\"#bf616a\">´çĚ</span>",
	  "dnd-none": "´çĚ",
	  "inhibited-notification": "<span color=\"#ebcb8b\">´éó</span>",
	  "inhibited-none": "´éó",
	  "dnd-inhibited-notification": "<span color=\"#bf616a\">´çĚ</span>",
	  "dnd-inhibited-none": "´çĚ"
	},
	"return-type": "json",
	"exec-if": "which swaync-client",
	"exec": "swaync-client -swb",
	"on-click": "sleep 0.1 && swaync-client -t -sw",
	"on-click-right": "swaync-client -d -sw",
        "escape": true,
    },
    "custom/power": {
        "format": "´ÇĹ",
	"on-click": "~/.config/waybar/scripts/powermenu.sh",
	"tooltip": false,
    },
    "upower#trackpad": {
    	"native-path": "hid-30:82:16:f1:83:d0-battery",
	"icon-size": 16,
	"hide-if-empty": true,
	"show-icon": false,
	"format": "ˇ░čŞ {percentage}",
	"format-alt": "ˇ░čŞ {percentage}"
    },
}
